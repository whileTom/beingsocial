# Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Gemini Multi-Key Setup (Recommended - FREE!)
# ============================================
# Add up to 4 Gemini API keys (comma-separated)
# Each key gets 20 req/day, 5 req/min limits
GEMINI_API_KEYS=key1,key2,key3,key4

# Models to rotate through (comma-separated)
# Options: gemini-2.0-flash-exp, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODELS=gemini-2.0-flash-exp,gemini-1.5-flash,gemini-1.5-flash,gemini-1.5-flash

# Rate limits per key (default: 20/day, 5/min)
GEMINI_DAILY_LIMIT=20
GEMINI_MINUTE_LIMIT=5

# ============================================
# Other AI Providers (Optional)
# ============================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AI Provider Strategy:
# - Leave AI_PROVIDER empty to rotate through all (recommended)
# - Or set to 'gemini', 'openai', or 'anthropic' to use only that one
AI_PROVIDER=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# Server
PORT=3000

# Polling interval in seconds
POLLING_INTERVAL=30
