{
  "name": "being-social",
  "version": "1.0.0",
  "description": "AI-powered message response bot for WhatsApp and Instagram",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec ts-node src/index.ts",
    "kill-bots": "powershell \"Get-Process node | Where-Object { $_.CommandLine -like '*src/index.ts*' } | Stop-Process -Force\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "login:ig": "ts-node src/scripts/login_instagram.ts",
    "login:ig:browser": "ts-node src/scripts/login_instagram_browser.ts"
  },
  "keywords": [
    "whatsapp",
    "instagram",
    "ai",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@google/genai": "^1.37.0",
    "@google/generative-ai": "^0.24.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/socket.io": "^3.0.1",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.66.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "instagram-private-api": "^1.46.1",
    "ioredis": "^5.9.2",
    "openai": "^6.16.0",
    "puppeteer": "^24.35.0",
    "puppeteer-core": "^24.35.0",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "telegraf": "^4.16.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "whatsapp-web.js": "^1.34.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "inquirer": "^8.2.7",
    "nodemon": "^3.1.11"
  }
}
